0 indent-0.5 w-50 flex float:left items-center"><span class="material-icons-regular text-[19px] text-[#a15959]">Manage_Accounts</span>Listar aulas</li></a> <?php endif; ?> <?php if ($this->user_role && $this->user_role !== 'guest'): ?> <a href="/logout"><li class="rounded-md hover:bg-slate-200 indent-0.5 w-50 flex float:left items-center font-semi-bold"><span class="material-icons-regular text-[19px] text-[#a15959]">Door_Open</span> Sair / logout</li></a> <?php endif; ?> </ul></nav></label></div></div></div><main class="grow"> <?= $this->content ?> </main><footer class="bg-gray-300 text-center text-gray-700 max-w-full text-sm mt-10">©2025 Axel Patinação Artística - Todos os direitos reservados.</footer><script>document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('containerMenu');
      const checkbox = document.getElementById('botaoMenu');
      let tempoParaFechar;
      if (container && checkbox) {
        // 1. Fechar ao sair do menu com o mouse
        container.addEventListener('mouseleave', () => {
          tempoParaFechar = setTimeout(() => {
            checkbox.checked = false;
          }, 80);
        });
        container.addEventListener('mouseenter', () => {
          clearTimeout(tempoParaFechar);
        });
        // 2. Fechar ao clicar FORA do container
        document.addEventListener('click', (e) => {
          var link = e.target.closest('a');
          if (link) {
            checkbox.checked = false;
          }
          // Se o clique NÃO foi dentro do containerMenu, fecha o checkbox
          if (!container.contains(e.target)) {
            checkbox.checked = false;
          }
        });

      }

    });</script></body></html>